# Supabase Lite - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: Generate these secrets (DO NOT use the defaults in production!)
# =============================================================================

# PostgreSQL password - generate with: openssl rand -base64 32
POSTGRES_PASSWORD=your-super-secret-postgres-password

# JWT Secret - MUST be at least 32 characters
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters

# Anon Key - JWT token for anonymous/public access
# Generate at: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# Or use the generate-keys.sh script
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Service Role Key - JWT token for admin/service access (keep secret!)
# Generate at: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# =============================================================================
# URLs - Update these for your NAS IP/hostname
# =============================================================================

# Your NAS IP or hostname (used for redirects after auth)
SITE_URL=http://localhost:4200

# API URL (Kong gateway)
API_EXTERNAL_URL=http://localhost:8001

# Additional redirect URLs (comma-separated, optional)
# ADDITIONAL_REDIRECT_URLS=http://192.168.1.100:4200,http://mynas.local:4200

# =============================================================================
# PORTS - Change if defaults conflict with existing services
# =============================================================================

# Kong API Gateway port (8001 to avoid conflict)
KONG_HTTP_PORT=8001

# Angular application port
APP_PORT=4200

# =============================================================================
# AUTH OPTIONS
# =============================================================================

# Set to true to disable new user registration
DISABLE_SIGNUP=false

# Set to false to require email verification (needs SMTP config)
MAILER_AUTOCONFIRM=true

# JWT token expiration in seconds (default: 1 hour)
JWT_EXPIRY=3600

# Admin email for system notifications
SMTP_ADMIN_EMAIL=admin@localhost
