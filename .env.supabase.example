# Reusable config for scripts/supabase-bootstrap.sh
#
# Copy to `.env.supabase` (gitignored) and fill in. Set these once — the
# bootstrap script reads them every time you stand up a new project, so you
# never retype secrets when a free-tier project pauses/expires.
#
#   cp .env.supabase.example .env.supabase

# --- Spotify app credentials (from https://developer.spotify.com/dashboard) ---
# The same Spotify app is reused across Supabase projects. Only the OAuth
# redirect URI changes per project (the script prints the one to add).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Cron secret guarding the refresh-releases function ---
# Any long random string. `openssl rand -hex 32` is fine. Reuse it or rotate.
CRON_SECRET=

# --- New-project creation (only needed when the script CREATES a project) ---
# Find your org id with: supabase orgs list
SUPABASE_ORG_ID=
# e.g. us-east-1, us-west-1, eu-central-1 (see: supabase projects create --help)
SUPABASE_REGION=us-east-1
# Prefix for the generated project name; a timestamp is appended.
SUPABASE_PROJECT_NAME=spot-radar
# Postgres password for the new project's database. Pick a strong one and keep it.
SUPABASE_DB_PASSWORD=

# --- Existing project (skip creation) ---
# If set, the script provisions THIS project instead of creating a new one.
# Leave blank to create a fresh project.
SUPABASE_PROJECT_REF=
